<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta http-equiv="refresh" content="30">
<title>met-to-wg status</title>
<style>
:root {
  color-scheme: light dark;
  --bg: #fafafa;
  --fg: #1f1f1f;
  --muted: #666;
  --card: #ffffff;
  --border: #e3e3e3;
  --accent: #1f6feb;
  --warn: #b3261e;
}
@media (prefers-color-scheme: dark) {
  :root {
    --bg: #14171c;
    --fg: #ececec;
    --muted: #9aa0a6;
    --card: #1e2228;
    --border: #2c3138;
    --accent: #4493f8;
    --warn: #ff7b72;
  }
}
* { box-sizing: border-box; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  margin: 0;
  background: var(--bg);
  color: var(--fg);
  line-height: 1.45;
}
header {
  padding: 24px 32px 8px;
}
header h1 {
  margin: 0;
  font-size: 20px;
  letter-spacing: 0.02em;
}
header .meta {
  color: var(--muted);
  font-size: 13px;
  margin-top: 4px;
}
main {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 16px;
  padding: 16px 32px 32px;
}
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 18px 20px;
}
.card h2 {
  margin: 0 0 12px;
  font-size: 16px;
  font-weight: 600;
}
.metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px 16px;
  margin-bottom: 14px;
}
.metric .label {
  font-size: 11px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.metric .value {
  font-size: 22px;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}
.latest {
  border-top: 1px solid var(--border);
  padding-top: 12px;
}
.latest h3 {
  margin: 0 0 8px;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--muted);
}
.kv {
  display: grid;
  grid-template-columns: max-content 1fr;
  gap: 4px 12px;
  font-size: 13px;
}
.kv dt { color: var(--muted); }
.kv dd { margin: 0; font-variant-numeric: tabular-nums; }
.empty { color: var(--muted); font-style: italic; }
.error {
  color: var(--warn);
  font-size: 13px;
  margin: 0;
}
footer {
  padding: 0 32px 24px;
  color: var(--muted);
  font-size: 12px;
}
</style>
</head>
<body>
<header>
  <h1>met-to-wg status</h1>
  <div class="meta">
    Generated {{ .GeneratedAt }} ·
    today since {{ .DayStart }} ·
    this week since {{ .WeekStart }}
  </div>
</header>
<main>
{{- range .Stations }}
  <section class="card">
    <h2>{{ .Name }}</h2>
    {{- if .Error }}
      <p class="error">storage error: {{ .Error }}</p>
    {{- else }}
      <div class="metrics">
        <div class="metric">
          <div class="label">Pulled today</div>
          <div class="value">{{ .PulledToday }}</div>
        </div>
        <div class="metric">
          <div class="label">Pulled this week</div>
          <div class="value">{{ .PulledWeek }}</div>
        </div>
        <div class="metric">
          <div class="label">Uploaded today</div>
          <div class="value">{{ .UploadedToday }}</div>
        </div>
        <div class="metric">
          <div class="label">Uploaded this week</div>
          <div class="value">{{ .UploadedWeek }}</div>
        </div>
      </div>
      <div class="latest">
        <h3>Latest measurement</h3>
        {{- if .Latest }}
          <dl class="kv">
            <dt>Observed</dt><dd>{{ .LatestLocal }}</dd>
            {{- if .LatestUploaded }}
            <dt>Uploaded</dt><dd>{{ .LatestUploaded }}</dd>
            {{- else }}
            <dt>Uploaded</dt><dd class="empty">not uploaded</dd>
            {{- end }}
            <dt>Wind avg</dt><dd>{{ printf "%.1f kn" .Latest.WindAvg }}</dd>
            <dt>Wind max</dt><dd>{{ floatOr .Latest.WindMax "%.1f kn" "—" }}</dd>
            <dt>Wind dir</dt><dd>{{ .Latest.WindDirection }}°</dd>
            <dt>Temperature</dt><dd>{{ floatOr .Latest.Temperature "%.1f °C" "—" }}</dd>
            <dt>Water temp</dt><dd>{{ floatOr .Latest.WaterTemperature "%.1f °C" "—" }}</dd>
            <dt>Humidity</dt><dd>{{ floatOr .Latest.RH "%.0f %%" "—" }}</dd>
            <dt>MSLP</dt><dd>{{ floatOr .Latest.MSLP "%.1f hPa" "—" }}</dd>
          </dl>
        {{- else }}
          <p class="empty">no observations recorded yet</p>
        {{- end }}
      </div>
    {{- end }}
  </section>
{{- else }}
  <section class="card"><p class="empty">no stations configured</p></section>
{{- end }}
</main>
<footer>auto-refreshes every 30s</footer>
</body>
</html>
